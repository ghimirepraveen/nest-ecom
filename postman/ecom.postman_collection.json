{
  "info": {
    "name": "ecom API",
    "_postman_id": "ecom-api-collection",
    "description": "Collection to test ecom NestJS API (auth + mail)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Register",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/auth/register" }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const res = pm.response.json();",
              "if (res.accessToken) pm.environment.set('accessToken', res.accessToken);",
              "if (res.refreshToken) pm.environment.set('refreshToken', res.refreshToken);",
              "pm.test('status is 200 or 201', ()=> pm.expect(pm.response.code).to.be.oneOf([200,201]));"
            ]
          }
        }
      ]
    },
    {
      "name": "Login",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/auth/login" }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const res = pm.response.json();",
              "if (res.accessToken) pm.environment.set('accessToken', res.accessToken);",
              "if (res.refreshToken) pm.environment.set('refreshToken', res.refreshToken);",
              "pm.test('status is 200', ()=> pm.expect(pm.response.code).to.equal(200));"
            ]
          }
        }
      ]
    },
    {
      "name": "Refresh Tokens",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{refreshToken}}"
          }
        ],
        "url": { "raw": "{{baseUrl}}/auth/refresh" }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const res = pm.response.json();",
              "if (res.accessToken) pm.environment.set('accessToken', res.accessToken);",
              "if (res.refreshToken) pm.environment.set('refreshToken', res.refreshToken);",
              "pm.test('status is 200', ()=> pm.expect(pm.response.code).to.equal(200));"
            ]
          }
        }
      ]
    },
    {
      "name": "Profile (protected)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": { "raw": "{{baseUrl}}/auth/profile" }
      }
    },
    {
      "name": "Mail Test",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/mail/test?to={{email}}&subject=Postman%20Test"
        }
      }
    }
  ]
}
