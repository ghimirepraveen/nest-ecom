{
  "info": {
    "name": "ecom API",
    "_postman_id": "ecom-api-collection",
    "description": "Collection to test ecom NestJS API (health, auth, customers, categories, and mail)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Get Hello",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/" }
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"{{authFullName}}\",\n  \"email\": \"{{authEmail}}\",\n  \"password\": \"{{authPassword}}\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/register" }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.accessToken) pm.environment.set('accessToken', res.accessToken);",
                  "if (res.refreshToken) pm.environment.set('refreshToken', res.refreshToken);",
                  "pm.test('status is 200 or 201', () => pm.expect(pm.response.code).to.be.oneOf([200, 201]));"
                ]
              }
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{authEmail}}\",\n  \"password\": \"{{authPassword}}\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/login" }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.accessToken) pm.environment.set('accessToken', res.accessToken);",
                  "if (res.refreshToken) pm.environment.set('refreshToken', res.refreshToken);",
                  "pm.test('status is 200', () => pm.expect(pm.response.code).to.equal(200));"
                ]
              }
            }
          ]
        },
        {
          "name": "Admin Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/login" }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.accessToken) pm.environment.set('adminAccessToken', res.accessToken);",
                  "if (res.refreshToken) pm.environment.set('adminRefreshToken', res.refreshToken);",
                  "pm.test('status is 200', () => pm.expect(pm.response.code).to.equal(200));"
                ]
              }
            }
          ]
        },
        {
          "name": "Customer Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{customerEmail}}\",\n  \"password\": \"{{customerPassword}}\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/login" }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.accessToken) pm.environment.set('customerAccessToken', res.accessToken);",
                  "if (res.refreshToken) pm.environment.set('customerRefreshToken', res.refreshToken);",
                  "pm.test('status is 200', () => pm.expect(pm.response.code).to.equal(200));"
                ]
              }
            }
          ]
        },
        {
          "name": "Verify Email",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{authEmail}}\",\n  \"otp\": \"{{otp}}\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/verify-email" }
          }
        },
        {
          "name": "Send OTP",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{authEmail}}\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/send-otp" }
          }
        },
        {
          "name": "Refresh Tokens",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{refreshToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/auth/refresh" }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.accessToken) pm.environment.set('accessToken', res.accessToken);",
                  "if (res.refreshToken) pm.environment.set('refreshToken', res.refreshToken);",
                  "pm.test('status is 200', () => pm.expect(pm.response.code).to.equal(200));"
                ]
              }
            }
          ]
        },
        {
          "name": "Profile (protected)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/auth/profile" }
          }
        }
      ]
    },
    {
      "name": "Customers",
      "item": [
        {
          "name": "Register Customer",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"{{customerFullName}}\",\n  \"email\": \"{{customerEmail}}\",\n  \"password\": \"{{customerPassword}}\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/customers/register" }
          }
        },
        {
          "name": "List Customers (admin)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminAccessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/customers?page={{page}}&limit={{limit}}"
            }
          }
        },
        {
          "name": "Get Customer By Id (admin)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminAccessToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/customers/{{customerId}}" }
          }
        }
      ]
    },
    {
      "name": "Categories",
      "item": [
        {
          "name": "Create Category (admin)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminAccessToken}}"
              },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"{{categoryName}}\",\n  \"description\": \"{{categoryDescription}}\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/category" }
          }
        },
        {
          "name": "List Categories (admin)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminAccessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/category?page={{page}}&limit={{limit}}"
            }
          }
        },
        {
          "name": "List Categories for Customer",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{customerAccessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/category/customer?page={{page}}&limit={{limit}}"
            }
          }
        },
        {
          "name": "Category For Select",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{customerAccessToken}}"
              }
            ],
            "url": { "raw": "{{baseUrl}}/category/for-select" }
          }
        },
        {
          "name": "Get Category By Id",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{customerAccessToken}}"
              }
            ],
            "url": { "raw": "{{baseUrl}}/category/{{categoryId}}" }
          }
        },
        {
          "name": "Update Category (admin)",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminAccessToken}}"
              },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"{{categoryName}}\",\n  \"description\": \"{{categoryDescription}}\",\n  \"isPublished\": true\n}"
            },
            "url": { "raw": "{{baseUrl}}/category/{{categoryId}}" }
          }
        },
        {
          "name": "Publish Category (admin)",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminAccessToken}}"
              },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"isPublished\": true\n}"
            },
            "url": { "raw": "{{baseUrl}}/category/{{categoryId}}/publish" }
          }
        }
      ]
    },
    {
      "name": "Mail",
      "item": [
        {
          "name": "Mail Test",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/mail/test?to={{mailTo}}&subject=Postman%20Test"
            }
          }
        }
      ]
    }
  ]
}
